# Internal 3x-ui subscription URL (localhost only after install)
THREE_XUI_SUB_URL=http://127.0.0.1:2097
# Public HWID port for VPN clients
PORT=2096
HOST=0.0.0.0
# Subscription path segment (without slashes): subs or sub
SUB_PATH=subs
# Server public IP for correct VLESS address in subscription (optional, auto-detected from Host header)
PUBLIC_HOST=
# Default device limit per subscription
DEFAULT_DEVICE_LIMIT=3
# Auto-unlink inactive devices after N days
DEVICE_TTL_DAYS=30
# Message shown in VPN client when limit exceeded
ERROR_PROXY_TEXT=⚠️ ЛИМИТ УСТРОЙСТВ ДОСТИГНУТ
# Master API token (Bearer)
API_BEARER_TOKEN=change_me
# Comma-separated IPs allowed without x-hwid (aggregators, bots)
TRUSTED_IPS=
